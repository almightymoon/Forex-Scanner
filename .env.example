# Database
DATABASE_URL=postgresql://fxnav:fxnav_dev@localhost:5432/fxnavigators
COLLECTOR_DATABASE_URL=postgresql://fxnav:fxnav_dev@localhost:5432/fxnavigators
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-production
MARKET_API_KEY=

# Market data collector
COLLECTOR_READ_ENABLED=true
COLLECTOR_DAEMON_ENABLED=true
ENABLE_COLLECTOR_DAEMON=false
COLLECTOR_SQLITE_PATH=data/collector.db

# Market Data — simulation is EXPLICIT opt-in only (never inferred from ENVIRONMENT)
ENABLE_SIMULATED_DATA=false

# Provider priority: Twelve Data → Polygon (see config/market.yaml)
MARKET_DATA_PROVIDER=twelvedata
TWELVE_DATA_API_KEY=
POLYGON_API_KEY=

# MT5 (Windows + MetaTrader5 terminal required)
# Enable in config/data_collector.yaml: providers.mt5.enabled

# AI (explanations only)
OPENAI_API_KEY=

# Notifications
TELEGRAM_BOT_TOKEN=
SMTP_HOST=
SMTP_PORT=587

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=

# Scanner daemon (set true to auto-scan when API starts)
ENABLE_SCANNER_DAEMON=false

# Prometheus: docker compose --profile monitoring up -d
